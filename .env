# Copy to .env and fill in values. Pydantic reads DATABASE_URL (same as database_url in Settings).

# Neon: Dashboard → Connection details → copy "URI" then swap scheme for SQLAlchemy:
#   postgresql://...  →  postgresql+psycopg2://...
# Always include SSL for Neon, e.g. end of URL: ?sslmode=require
# If the password has @ # % etc., URL-encode it (Neon's UI often gives a ready-to-paste string).
DATABASE_URL=postgresql://neondb_owner:npg_7cGe5BVXTKMa@ep-muddy-tree-aq4vk60z-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# App + Alembic: tables live here so we do not clash with Neon/public tables (e.g. notifications).
DATABASE_SCHEMA=rental_mgr

# Optional overrides (defaults exist in app/config.py)
# ENVIRONMENT=development
# SECRET_KEY=your-long-random-secret
