# Copy to .env and fill in values.

# Neon: Connection details → URI, then change scheme for SQLAlchemy + psycopg2:
#   postgresql://...  →  postgresql+psycopg2://...
# Include SSL, e.g. ...?sslmode=require
# Use postgresql+psycopg2://... if you prefer an explicit driver in the URL.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Postgres schema for ORM + Alembic (avoids clashes with Neon/public tables like notifications).
# Use "public" only if this database has no conflicting public tables.
DATABASE_SCHEMA=rental_mgr

# API base URL for links inside emails (must be reachable from the internet when using real SMTP)
# API_PUBLIC_BASE_URL=http://localhost:8000

# Where email verification redirects the browser after GET /auth/verify-email (no trailing slash)
# FRONTEND_BASE_URL=http://localhost:5173

# Optional
# ENVIRONMENT=development
# SECRET_KEY=your-long-random-secret
